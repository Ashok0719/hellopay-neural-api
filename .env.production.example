# HelloPay - Neural Backend Production Config
# Copy this file to '.env' in your production environment (Render/Railway)

# [SYSTEM]
NODE_ENV=production
PORT=5000

# [DATABASE]
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/hellopay?retryWrites=true&w=majority

# [SECURITY]
JWT_SECRET=your_long_random_neural_secret_here
ALLOWED_ORIGINS=https://hellopayapp.com,https://admin.hellopayapp.com

# [PAYMENT GATEWAY - RAZORPAY]
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# [OTP / TELEGRAM (Optional)]
TELEGRAM_BOT_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=xxxxxxxxxxxxxxxxxxxxxxxx
